{
  "meta": {
    "title": "HHI Governance Glossary",
    "version": "1.2.0",
    "license": "HHI-LUL-01",
    "authority": "HHI-MLS",
    "source": "Hollow House Institute"
  },
  "glossary": [
    {
      "id": "governance",
      "term": "Governance",
      "definition": "The infrastructure that determines how behavior accumulates, compounds, and constrains action over time.",
      "notes": [
        "Operates at execution time, not documentation time.",
        "Binds authority before reliance forms.",
        "Policy describes intent; governance constrains behavior."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "governance-infrastructure",
      "term": "Governance Infrastructure",
      "definition": "Durable formal and informal structures that shape how decisions, authority, and accountability are exercised over time.",
      "notes": [
        "Includes habits, incentives, norms, tooling, and enforcement.",
        "Persists even when policy changes.",
        "Behavior is both input and output."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "decision-boundary",
      "term": "Decision Boundary",
      "definition": "The explicit point at which authority transfers between system and human roles during execution.",
      "notes": [
        "Must be defined before deployment.",
        "Undefined boundaries cause implicit authority transfer."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "authority",
      "term": "Authority",
      "definition": "The formally assigned right to decide, override, pause, or stop an action at execution time.",
      "notes": [
        "Must be role-bound and explicit.",
        "Inferred authority is not governed authority."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "stop-authority",
      "term": "Stop Authority",
      "definition": "A role-bound capability to pause, override, or decommission a system or process at runtime.",
      "notes": [
        "Must be exercisable under pressure.",
        "Symbolic authority is insufficient."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "human-in-the-loop",
      "term": "Human-in-the-Loop",
      "definition": "A governance condition in which humans retain final decision authority at defined execution points.",
      "notes": [
        "Non-bypassable.",
        "Required for accountability."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "behavioral-drift",
      "term": "Behavioral Drift",
      "definition": "Gradual behavioral change resulting from repeated interaction with a system over time.",
      "notes": [
        "Often invisible in short-term evaluation.",
        "Occurs even when systems function as designed."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "behavioral-accumulation",
      "term": "Behavioral Accumulation",
      "definition": "The compounding effect of repeated behavior that reshapes judgment, escalation readiness, and accountability norms.",
      "notes": [
        "Primary driver of longitudinal risk.",
        "Hardens into infrastructure."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "decision-substitution",
      "term": "Decision Substitution",
      "definition": "The incremental replacement of human judgment by system output as the default decision reference.",
      "notes": [
        "Does not require explicit delegation.",
        "Often precedes formal automation."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "escalation",
      "term": "Escalation",
      "definition": "The transfer of decision authority in response to uncertainty, risk, or ambiguity.",
      "notes": [
        "Must be structurally enforced.",
        "Paper-only escalation is non-functional."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "escalation-decay",
      "term": "Escalation Decay",
      "definition": "The erosion of an organization’s ability to recognize, initiate, or complete escalation pathways over time.",
      "notes": [
        "Structural, not individual.",
        "Often visible only after failure."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "confidence-reinforcement",
      "term": "Confidence Reinforcement",
      "definition": "A feedback process in which repeated system confirmation increases user confidence independent of objective accuracy.",
      "notes": [
        "Amplifies trust asymmetrically.",
        "Reduces skepticism and override readiness."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "normalization-of-workarounds",
      "term": "Normalization of Workarounds",
      "definition": "The process by which informal fixes become embedded as standard operating behavior.",
      "notes": [
        "Often begin as adaptation.",
        "Reshape governance reality over time."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "longitudinal-risk",
      "term": "Longitudinal Risk",
      "definition": "Risk that emerges through accumulation and adaptation over time rather than discrete events.",
      "notes": [
        "Not captured by snapshot audits.",
        "Requires temporal observation."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "accountability",
      "term": "Accountability",
      "definition": "The binding of outcomes to named roles with recognized authority prior to execution.",
      "notes": [
        "Post-failure attribution is forensic, not governing.",
        "Clear accountability enables correction."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "accountability-diffusion",
      "term": "Accountability Diffusion",
      "definition": "Loss of clear responsibility attribution from distributed or mediated decision processes.",
      "notes": [
        "Increases with complexity.",
        "Impairs intervention and repair."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "override-erosion",
      "term": "Override Erosion",
      "definition": "Reduced ability or willingness to override system outputs or established processes.",
      "notes": [
        "Distinct from lack of formal authority.",
        "Increases systemic fragility."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },

    {
      "id": "stable-mirror-failure",
      "term": "Stable Mirror Failure",
      "definition": "A governance failure in which existing feedback mechanisms adapt to authority behavior rather than consistently reflecting it.",
      "notes": [
        "Appears as supportive tooling that stops challenging behavior.",
        "Dashboards optimizing reassurance are common examples.",
        "Adaptive feedback cannot function as governance infrastructure."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "authority-persistence",
      "term": "Authority Persistence",
      "definition": "The continuation of decision-making power beyond the period in which governance oversight is active or effective.",
      "notes": [
        "Risk increases when mirrors degrade."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "governance-lag",
      "term": "Governance Lag",
      "definition": "The delay between behavioral change and governance recognition or response.",
      "notes": [
        "Increases silently during success.",
        "Reducing lag is more effective than adding control."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "escalation-suppression",
      "term": "Escalation Suppression",
      "definition": "Behavioral inhibition of escalation due to social or efficiency pressures.",
      "notes": [
        "Often precedes escalation decay.",
        "Behavioral, not procedural."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "judgment-externalization",
      "term": "Judgment Externalization",
      "definition": "The transfer of interpretive responsibility from human actors to system outputs over time.",
      "notes": [
        "Precursor to decision substitution.",
        "Reduces independent sense-making."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "behavioral-lock-in",
      "term": "Behavioral Lock-In",
      "definition": "The point at which repeated behavior becomes resistant to correction due to institutionalization or habit.",
      "notes": [
        "Occurs before formal policy change.",
        "Early mirrors prevent lock-in."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "mirror-latency",
      "term": "Mirror Latency",
      "definition": "The delay between behavior execution and reflective feedback reaching the authority actor.",
      "notes": [
        "High latency enables drift.",
        "Latency is a governance variable."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "governance-illusion",
      "term": "Governance Illusion",
      "definition": "The appearance of governance created by documentation, policy, or tooling that lacks behavioral enforcement.",
      "notes": [
        "Reinforced by compliance artifacts.",
        "Collapses under pressure."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "authority-saturation",
      "term": "Authority Saturation",
      "definition": "A condition in which authority actors are overloaded such that governance signals are ignored or deferred.",
      "notes": [
        "Leads to reliance on automation.",
        "Governance must account for human limits."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },{
  "id": "human-ai-interaction",
  "term": "Human–AI Interaction (Governance Context)",
  "definition": "Structured engagement between humans and AI-mediated systems affecting judgment, authority, and responsibility.",
  "notes": [
    "Governance-focused, not anthropomorphic.",
    "Risk arises from interaction patterns."
  ],
  "scope": [
    "HHI_GOV_01",
    "Execution-Time Governance",
    "Audit Evaluation"
  ],
  "authority_level": "standard",
  "allowed_uses": [
    "behavior evaluation",
    "governance rule reference",
    "audit criteria"
  ],
  "disallowed_uses": [
    "model training labels",
    "marketing claims",
    "post-hoc justification"
  ]
},
    {
      "id": "silent-load-transfer",
      "term": "Silent Load Transfer",
      "definition": "The unacknowledged movement of regulatory, emotional, or decision burden from authority roles to dependent actors.",
      "notes": [
        "Often mistaken for resilience.",
        "Creates inherited regulation failure."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "continuous-assurance",
      "term": "Continuous Assurance",
      "definition": "Ongoing monitoring of system behavior and compliance controls in production.",
      "notes": [
        "Replaces episodic audits.",
        "Detects drift early."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    },
    {
      "id": "agentic-workflows",
      "term": "Agentic Workflows",
      "definition": "Coordinated systems where multiple AI agents perform interdependent tasks under governance constraints.",
      "notes": [
        "Human escalation paths required.",
        "Audit logging required."
      ],
      "scope": ["HHI_GOV_01","Execution-Time Governance","Audit Evaluation"],
      "authority_level": "standard",
      "allowed_uses": ["behavior evaluation","governance rule reference","audit criteria"],
      "disallowed_uses": ["model training labels","marketing claims","post-hoc justification"]
    }
  ],
