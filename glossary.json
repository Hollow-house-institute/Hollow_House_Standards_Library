"meta": {
    "title": "HHI Governance Glossary",
    "version": "1.3.0",
    "canonical_terms": 41,
    "status": "Governance Freeze",
    "authority": "Hollow House Institute",
    "license": "HHI-LUL-01",
    "source": "https://github.com/hhidatasettechs-oss/Hollow_House_Standards_Library",
    "description": "Canonical terminology registry for Hollow House Institute governance standards."
  },
  "terms": [
    {
      "id": "sovereign-ai-stack",
      "term": "Sovereign AI Stack",
      "definition": "An AI architecture in which control over data, models, infrastructure, governance rules, and deployment authority is retained by the operating entity.",
      "notes": [
        "Requires enforceable data lineage",
        "Does not require open-source",
        "Requires governance transparency"
      ]
    },
    {
      "id": "data-rails",
      "term": "Data Rails",
      "definition": "Governance-controlled infrastructure pathways that enable secure data exchange without centralization into proprietary silos.",
      "notes": [
        "Includes access control and traceability",
        "Supports contractual enforcement"
      ]
    },
    {
      "id": "agentic-workflows",
      "term": "Agentic Workflows",
      "definition": "Coordinated systems in which multiple AI agents perform interdependent tasks under explicit governance constraints.",
      "notes": [
        "Includes human escalation paths",
        "Requires audit logging"
      ]
    },
    {
      "id": "continuous-assurance",
      "term": "Continuous Assurance",
      "definition": "A governance approach that replaces episodic audits with ongoing monitoring of system behavior and compliance controls.",
      "notes": [
        "Operates in production",
        "Enables early drift detection"
      ]
    },
    {
      "id": "stable-mirror-failure",
      "term": "Stable Mirror Failure",
      "definition": "A governance failure in which feedback mechanisms adapt to authority behavior rather than accurately reflecting it.",
      "notes": [
        "Appears as supportive tooling",
        "Undermines corrective challenge"
      ]
    },
    {
      "id": "authority-persistence",
      "term": "Authority Persistence",
      "definition": "The continuation of decision power beyond the period where governance oversight remains effective.",
      "notes": [
        "Not inherently dangerous",
        "Becomes risky when mirrors degrade"
      ]
    },
    {
      "id": "governance-lag",
      "term": "Governance Lag",
      "definition": "The delay between behavioral change and governance recognition or response.",
      "notes": [
        "Increases silently during success",
        "Reducing lag is more effective than increasing control"
      ]
    },
    {
      "id": "escalation-suppression",
      "term": "Escalation Suppression",
      "definition": "Behavioral inhibition of escalation due to cultural, social, or efficiency pressures rather than formal restriction.",
      "notes": [
        "Often precedes escalation decay",
        "Behavioral, not procedural"
      ]
    },
    {
      "id": "judgment-externalization",
      "term": "Judgment Externalization",
      "definition": "The transfer of interpretive responsibility from human actors to system outputs over time.",
      "notes": [
        "Precursor to decision substitution",
        "Difficult to reverse once normalized"
      ]
    },
    {
      "id": "silent-load-transfer",
      "term": "Silent Load Transfer",
      "definition": "The unacknowledged movement of regulatory, emotional, or decision burden from authority roles to dependent actors.",
      "notes": [
        "Often mistaken for resilience",
        "Creates inherited regulation failure"
      ]
    },
    {
      "id": "behavioral-lock-in",
      "term": "Behavioral Lock-In",
      "definition": "The point at which repeated behavior becomes resistant to correction due to institutionalization or habit.",
      "notes": [
        "Occurs before policy change",
        "Early mirrors prevent lock-in"
      ]
    },
    {
      "id": "mirror-latency",
      "term": "Mirror Latency",
      "definition": "The delay between behavior execution and reflective feedback reaching authority actors.",
      "notes": [
        "Enables drift even when mirrors exist",
        "Latency is a governance variable"
      ]
    },
    {
      "id": "governance-illusion",
      "term": "Governance Illusion",
      "definition": "The appearance of governance created by documentation or tooling without behavioral enforcement.",
      "notes": [
        "Collapses under pressure",
        "Indistinguishable until tested"
      ]
    },
    {
      "id": "authority-saturation",
      "term": "Authority Saturation",
      "definition": "A condition in which authority responsibilities exceed human operational capacity.",
      "notes": [
        "Leads to automation reliance",
        "Governance must account for human limits"
      ]
    },

    { "term": "Behavioral Drift", "definition": "Gradual divergence between expected system behavior and observed behavior over time." },
    { "term": "Reliance Formation", "definition": "Process by which individuals or organizations begin depending on system outputs regardless of governance approval." },
    { "term": "Governance as Infrastructure", "definition": "Repeated behavioral patterns embedded within operational systems." },
    { "term": "Post-Hoc Governance", "definition": "Governance actions occurring only after outcomes are questioned or failures occur." },
    { "term": "Continuous Assurance", "definition": "Continuous monitoring of governance performance rather than periodic audits." },
    { "term": "Longitudinal Accountability", "definition": "Traceability of responsibility and decision authority across time." },
    { "term": "Authority", "definition": "Formally assigned right to make decisions within a system." },
    { "term": "Decision Boundary", "definition": "Point where decision authority transfers between actors." },
    { "term": "Stop Authority", "definition": "Capability to halt system operations when governance thresholds are exceeded." },
    { "term": "Human-in-the-Loop", "definition": "Governance mechanism requiring human oversight in decision processes." },
    { "term": "Escalation", "definition": "Transfer of decisions to higher authority when risk thresholds are met." },
    { "term": "Escalation Decay", "definition": "Reduction in effectiveness or use of escalation pathways over time." },
    { "term": "Escalation Suppression", "definition": "Condition where escalation pathways exist but are not used." },
    { "term": "Authority Persistence", "definition": "Continuation of decision authority beyond original conditions." },
    { "term": "Human Authority", "definition": "The principle that humans retain final decision authority and ethical accountability in AI-mediated systems.", "domain": "Governance", "status": "canonical", "introduced": "v1.0.0" },
    { "term": "Accountability", "definition": "Assignment of responsibility for decisions and outcomes." },
    { "term": "Accountability Diffusion", "definition": "Loss of clear responsibility due to distributed decision processes." },
    { "term": "Responsibility Binding", "definition": "Mechanism linking authority to responsible actors." },
    { "term": "Decision Substitution", "definition": "Replacement of human decision-making with automated outputs." },
    { "term": "Governance Lag", "definition": "Delay between behavioral change and governance response." },
    { "term": "Governance Drift", "definition": "Gradual misalignment between governance policy and operational behavior." },
    { "term": "Longitudinal Risk", "definition": "Risk emerging from cumulative behavior over time." },
    { "term": "Behavioral Accumulation", "definition": "Compounding effect of repeated actions reshaping system behavior." },
    { "term": "Governance Failure", "definition": "Breakdown of governance mechanisms controlling system behavior." },
    { "term": "Authority Drift", "definition": "Gradual shift in decision authority away from intended structures." },
    { "term": "Intervention Threshold", "definition": "Point where governance intervention becomes necessary." },
    { "term": "Judgment Externalization", "definition": "Transfer of decision reasoning from humans to external systems." },
    { "term": "Confidence Reinforcement", "definition": "Feedback loop where system responses increase user confidence." },
    { "term": "Override Erosion", "definition": "Decline in willingness to override automated decisions." },
    { "term": "Normalization of Workarounds", "definition": "Temporary fixes becoming permanent operational practices." },
    { "term": "Governance Illusion", "definition": "Perception of governance control without effective enforcement." },
    { "term": "Language Symmetry Score", "abbreviation": "LSS", "definition": "Metric evaluating alignment between outputs and governance terminology." },
    { "term": "Relational Rhythm Index", "abbreviation": "RRI", "definition": "Measure of stability in human-system interaction patterns." },
    { "term": "Governance Stability Index", "abbreviation": "GSI", "definition": "Indicator of long-term governance consistency." },
    { "term": "Authority Alignment Score", "abbreviation": "AAS", "definition": "Metric measuring alignment between authority and governance design." },
    { "term": "Relational Health Dashboard", "definition": "Monitoring interface for human-system interaction dynamics." },
    { "term": "Governance Telemetry", "definition": "Operational signals measuring governance performance." },
    { "term": "Interaction Trace", "definition": "Recorded sequence of human-system interactions." },
    { "term": "Sociotechnical System", "definition": "System composed of human, technical, and organizational components." },
    { "term": "Execution-Time Governance", "definition": "Governance mechanisms operating during system execution." },
    { "term": "Governance Infrastructure Layer", "definition": "Structural elements enforcing governance rules." },
    { "term": "Governance Surface", "definition": "Observable layer where governance interactions occur." }
  ]
}
