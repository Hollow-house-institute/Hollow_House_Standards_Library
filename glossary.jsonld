{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "HHI Governance Glossary",
  "description": "Canonical terminology registry defining governance concepts used in Behavioral AI Governance and Execution-Time Governance systems.",
  "creator": "Hollow House Institute",
  "url": "https://github.com/hhidatasettechs-oss/Hollow_House_Standards_Library",
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "name": "Governance",
      "identifier": "HHI-GOV-001",
      "description": "The infrastructure that determines how behavior accumulates, compounds, and constrains action over time.",
      "termCode": "governance",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Infrastructure",
      "identifier": "HHI-GOV-002",
      "description": "Durable formal and informal structures shaping how authority, decisions, and accountability operate over time.",
      "termCode": "governance-infrastructure",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Decision Boundary",
      "identifier": "HHI-AUTH-001",
      "description": "The explicit point at which authority transfers between actors during execution.",
      "termCode": "decision-boundary",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Authority",
      "identifier": "HHI-AUTH-002",
      "description": "The formally assigned right to make, override, pause, or stop decisions during execution.",
      "termCode": "authority",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Stop Authority",
      "identifier": "HHI-AUTH-003",
      "description": "A role-bound capability to pause or halt system operation when governance thresholds are exceeded.",
      "termCode": "stop-authority",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Behavioral Drift",
      "identifier": "HHI-BEH-001",
      "description": "Gradual divergence between expected system behavior and observed behavior over time.",
      "termCode": "behavioral-drift",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Behavioral Accumulation",
      "identifier": "HHI-BEH-002",
      "description": "The compounding effect of repeated actions reshaping system behavior over time.",
      "termCode": "behavioral-accumulation",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Decision Substitution",
      "identifier": "HHI-AUTH-004",
      "description": "Incremental replacement of human judgment with system outputs as the default decision reference.",
      "termCode": "decision-substitution",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Escalation",
      "identifier": "HHI-GOV-003",
      "description": "Transfer of decision authority to higher roles when uncertainty or risk thresholds are reached.",
      "termCode": "escalation",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Escalation Decay",
      "identifier": "HHI-GOV-004",
      "description": "Progressive erosion of an organization's ability to initiate or complete escalation pathways.",
      "termCode": "escalation-decay",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Confidence Reinforcement",
      "identifier": "HHI-BEH-003",
      "description": "Feedback process where repeated system confirmation increases user confidence regardless of objective accuracy.",
      "termCode": "confidence-reinforcement",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Normalization of Workarounds",
      "identifier": "HHI-GOV-005",
      "description": "Temporary fixes gradually becoming accepted as standard operational behavior.",
      "termCode": "normalization-of-workarounds",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Longitudinal Risk",
      "identifier": "HHI-RISK-001",
      "description": "Risk emerging through repeated behavior over time rather than discrete events.",
      "termCode": "longitudinal-risk",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Accountability",
      "identifier": "HHI-GOV-006",
      "description": "Binding outcomes to named roles with authority prior to execution.",
      "termCode": "accountability",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Accountability Diffusion",
      "identifier": "HHI-GOV-007",
      "description": "Loss of clear responsibility caused by distributed or mediated decision processes.",
      "termCode": "accountability-diffusion",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Override Erosion",
      "identifier": "HHI-BEH-004",
      "description": "Decline in willingness or ability to override system outputs.",
      "termCode": "override-erosion",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Human\u2013AI Interaction (Governance Context)",
      "identifier": "HHI-INT-001",
      "description": "Repeated engagement between humans and AI systems affecting judgment, authority, and responsibility.",
      "termCode": "human-ai-interaction",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Debt",
      "identifier": "HHI-GOV-008",
      "description": "Risk accumulated when AI deployment outpaces governance design.",
      "termCode": "governance-debt",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Reliance Formation",
      "identifier": "HHI-GOV-009",
      "description": "Process through which individuals begin depending on system outputs.",
      "termCode": "reliance-formation",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Post-Hoc Governance",
      "identifier": "HHI-GOV-010",
      "description": "Governance actions applied after outcomes are questioned or failures occur.",
      "termCode": "post-hoc-governance",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Continuous Assurance",
      "identifier": "HHI-GOV-011",
      "description": "Ongoing monitoring of governance performance rather than periodic auditing.",
      "termCode": "continuous-assurance",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Longitudinal Accountability",
      "identifier": "HHI-GOV-012",
      "description": "Traceability of authority and responsibility across time.",
      "termCode": "longitudinal-accountability",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Human Authority",
      "identifier": "HHI-AUTH-005",
      "description": "Principle that humans retain final decision authority and ethical accountability.",
      "termCode": "human-authority",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Authority Drift",
      "identifier": "HHI-AUTH-006",
      "description": "Gradual shift in decision authority away from intended governance structures.",
      "termCode": "authority-drift",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Drift",
      "identifier": "HHI-GOV-013",
      "description": "Misalignment between governance policy and operational behavior.",
      "termCode": "governance-drift",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Failure",
      "identifier": "HHI-GOV-014",
      "description": "Breakdown of governance mechanisms controlling system behavior.",
      "termCode": "governance-failure",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Intervention Threshold",
      "identifier": "HHI-RISK-002",
      "description": "Point where governance intervention becomes necessary.",
      "termCode": "intervention-threshold",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Judgment Externalization",
      "identifier": "HHI-GOV-015",
      "description": "Transfer of interpretive responsibility from humans to automated systems.",
      "termCode": "judgment-externalization",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Illusion",
      "identifier": "HHI-GOV-016",
      "description": "Perception of governance control without real enforcement.",
      "termCode": "governance-illusion",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Authority Saturation",
      "identifier": "HHI-AUTH-007",
      "description": "Condition where authority responsibilities exceed human operational capacity.",
      "termCode": "authority-saturation",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Language Symmetry Score",
      "identifier": "HHI-MET-001",
      "description": "Metric measuring alignment between system outputs and governance terminology.",
      "termCode": "language-symmetry-score",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Relational Rhythm Index",
      "identifier": "HHI-MET-002",
      "description": "Indicator measuring stability in human-system interaction patterns.",
      "termCode": "relational-rhythm-index",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Stability Index",
      "identifier": "HHI-GOV-017",
      "description": "Metric measuring long-term consistency of governance behavior.",
      "termCode": "governance-stability-index",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Authority Alignment Score",
      "identifier": "HHI-AUTH-008",
      "description": "Metric evaluating alignment between authority structures and governance design.",
      "termCode": "authority-alignment-score",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Relational Health Dashboard",
      "identifier": "HHI-MET-003",
      "description": "Monitoring interface displaying human-system interaction dynamics.",
      "termCode": "relational-health-dashboard",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Telemetry",
      "identifier": "HHI-GOV-018",
      "description": "Operational signals measuring governance performance.",
      "termCode": "governance-telemetry",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Interaction Trace",
      "identifier": "HHI-INT-002",
      "description": "Recorded sequence of human-system interactions.",
      "termCode": "interaction-trace",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Sociotechnical System",
      "identifier": "HHI-SYS-001",
      "description": "System composed of human, technical, and organizational components.",
      "termCode": "sociotechnical-system",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Execution-Time Governance",
      "identifier": "HHI-GOV-019",
      "description": "Governance mechanisms operating during system execution.",
      "termCode": "execution-time-governance",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Infrastructure Layer",
      "identifier": "HHI-GOV-020",
      "description": "Structural components enforcing governance rules.",
      "termCode": "governance-infrastructure-layer",
      "inDefinedTermSet": "HHI Governance Glossary"
    },
    {
      "@type": "DefinedTerm",
      "name": "Governance Surface",
      "identifier": "HHI-GOV-021",
      "description": "Observable interface where governance interactions occur.",
      "termCode": "governance-surface",
      "inDefinedTermSet": "HHI Governance Glossary"
    }
  ]
}