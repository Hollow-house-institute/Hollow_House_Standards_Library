@prefix hhi: <https://hollowhouse.org/ontology#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

hhi:GovernanceTerm a rdf:Class ;
    dct:description "Class representing canonical governance terminology defined by the HHI Governance Glossary." .

hhi:GovernanceDrift a hhi:GovernanceTerm ;
    hhi:identifier "HHI-GOV-013" ;
    dct:title "Governance Drift" ;
    dct:description "Divergence between documented governance policy and actual operational behavior over time." .

hhi:BehavioralDrift a hhi:GovernanceTerm ;
    hhi:identifier "HHI-BEH-001" ;
    dct:title "Behavioral Drift" ;
    dct:description "Gradual shift in system or operator behavior away from expected operational patterns." .

hhi:DecisionSubstitution a hhi:GovernanceTerm ;
    hhi:identifier "HHI-AUTH-004" ;
    dct:title "Decision Substitution" ;
    dct:description "Replacement of human judgment with automated output in operational decision processes." .

hhi:OverrideErosion a hhi:GovernanceTerm ;
    hhi:identifier "HHI-BEH-004" ;
    dct:title "Override Erosion" ;
    dct:description "Reduction in the frequency or willingness of operators to challenge system outputs." .

hhi:GovernanceDrift hhi:relatedTo hhi:BehavioralDrift .
hhi:DecisionSubstitution hhi:relatedTo hhi:OverrideErosion .
